{
  "private": true,
  "dependencies": {
    "markdownlint-cli2": "0.21.0",
    "textlint": "15.5.4",
    "textlint-rule-ja-space-between-half-and-full-width": "2.4.2",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-prh": "6.1.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "8.3.2",
    "hono": "4.12.12",
    "jose": "6.2.2"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "lint:docs": "typos docs && markdownlint-cli2 \"docs/**/*.md\" && textlint \"docs/**/*.md\"",
    "format:docs": "typos docs --write-changes && markdownlint-cli2 \"docs/**/*.md\" --fix && textlint \"docs/**/*.md\" --fix"
  }
}
